# Local bot runtime template
# Copy to .env.local for laptop / workstation runtime.
# Server runtime layering envs are injected by systemd on deploy.
# Keep QQBOT_ENV_BASE_FILE / QQBOT_ENV_OVERRIDE_FILE / CHATLUNA_PRESET_DIRS unset here.

# Core Bot
BOT_OWNER_QQ=2219854433
ONEBOT_SELF_ID=100000001
ONEBOT_WS_ENDPOINT=ws://127.0.0.1:3001
ONEBOT_TOKEN=
KOISHI_HOST=0.0.0.0
KOISHI_PORT=5140
KOISHI_CONSOLE_UI_PATH=/console
SQLITE_PATH=./data/koishi.db
CHATLUNA_COMMAND_AUTHORITY=3
CHATLUNA_DEFAULT_PRESET=sakiko
CHATLUNA_ACTIVE_TAB=siliconflow
CHATLUNA_PLATFORM=siliconflow
CHATLUNA_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
CHATLUNA_SILICONFLOW_API_KEY=sk-xxxx
CHATLUNA_SILICONFLOW_DEFAULT_MODEL=Pro/moonshotai/Kimi-K2.5
CHATLUNA_OPENAI_BASE_URL=https://shell.wyzai.top/v1
CHATLUNA_OPENAI_API_KEY=sk-xxxx
CHATLUNA_OPENAI_DEFAULT_MODEL=openai/gpt-5.4-medium-thinking
CHATLUNA_COPILOT_BASE_URL=http://127.0.0.1:5140/api/internal/copilot/v1
CHATLUNA_COPILOT_API_KEY=qqbot-copilot-bridge-secret
CHATLUNA_COPILOT_DEFAULT_MODEL=openai/gpt-5.4-mini
CHATLUNA_COPILOT_OAUTH_CLIENT_ID=Iv1.b507a08c87ecfe98
CHATLUNA_DEEPSEEK_BASE_URL=https://api.deepseek.com
CHATLUNA_DEEPSEEK_API_KEY=sk-xxxx
CHATLUNA_DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
CHATLUNA_BASE_URL=https://api.siliconflow.cn/v1
CHATLUNA_API_KEY=sk-xxxx
CHATLUNA_DEFAULT_MODEL=Pro/moonshotai/Kimi-K2.5
CHATLUNA_MAX_CONTEXT_RATIO=0.35
# Group Natural Trigger (群聊自然触发)
CHAT_NATURAL_TRIGGER_ENABLED=true
QQBOT_REALTIME_MESSAGE_ENABLED=true
QQBOT_REALTIME_MESSAGE_MAX_INJECT_COUNT=12
CHATLUNA_STORAGE_SERVER_PATH=http://127.0.0.1:5140
CHATLUNA_STORAGE_PATH=./data/chatluna-storage
CHATLUNA_STORAGE_BACKEND_PATH=/chatluna-storage
CHATLUNA_STORAGE_TEMP_CACHE_HOURS=720
CHATLUNA_STORAGE_MAX_MB=2048
CHATLUNA_STORAGE_MAX_FILES=2000
QQBOT_ATTACHMENT_MAX_INJECT_COUNT=5
QQBOT_ATTACHMENT_MAX_INJECT_TOTAL_BYTES=16777216
QQBOT_ATTACHMENT_MAX_INJECT_PER_FILE_BYTES=6291456
QQBOT_ATTACHMENT_MAX_PDF_PREVIEW_PAGES_PER_FILE=6
QQBOT_ATTACHMENT_MAX_PDF_PREVIEW_PAGES_TOTAL=15
QQBOT_ATTACHMENT_MAX_TEXT_CHARS_PER_FILE=24000
QQBOT_ATTACHMENT_RECENT_CATALOG_SIZE=12
QQBOT_ATTACHMENT_MAX_REQUEST_BODY_BYTES=20971520
# 留空表示不在任何群自动触发；请自行填写白名单群号。
CHAT_NATURAL_TRIGGER_GROUPS=
CHAT_NATURAL_TRIGGER_ALIASES=祥子,祥,丰川,丰川祥子,saki,saki酱,sakiko
CHAT_NATURAL_TRIGGER_DIRECT_PROBABILITY=0.25
CHAT_NATURAL_TRIGGER_FOCUS_WINDOW_MS=300000
CHAT_NATURAL_TRIGGER_REPLY_INTERVAL_MS=2000
CHAT_NATURAL_TRIGGER_SPAM_WINDOW_MS=10000
CHAT_NATURAL_TRIGGER_SPAM_THRESHOLD=10
CHAT_NATURAL_TRIGGER_SPAM_MUTE_MS=180000
CHAT_NATURAL_TRIGGER_DECISION_ENABLED=true
CHAT_NATURAL_TRIGGER_DECISION_BASE_URL=
CHAT_NATURAL_TRIGGER_DECISION_API_KEY=
CHAT_NATURAL_TRIGGER_DECISION_MODEL=
CHAT_NATURAL_TRIGGER_DECISION_TIMEOUT_MS=4000
CHAT_NATURAL_TRIGGER_DECISION_MIN_CONFIDENCE=0.62

# Task Automation (智能定时任务)
TASK_AUTOMATION_POLL_MS=30000
TASK_AUTOMATION_MAX_TASKS_PER_USER=20

# QQ Voice (QQ 语音输入/输出)
QQ_VOICE_INPUT_ENABLED=true
QQ_VOICE_OUTPUT_ENABLED=true
QQ_VOICE_ASR_BASE_URL=http://127.0.0.1:5161
QQ_VOICE_ASR_API_KEY=qqbot-voice-asr-token
QQ_VOICE_TTS_BASE_URL=http://127.0.0.1:5162
QQ_VOICE_TTS_API_KEY=qqbot-voice-tts-token
QQ_VOICE_BRIDGE_API_KEY=qqbot-voice-bridge-secret
QQ_VOICE_INPUT_MAX_SECONDS=60
QQ_VOICE_OUTPUT_MAX_WORDS=80
QQ_VOICE_OUTPUT_MAX_SECONDS=45
QQ_VOICE_TRANSCRIBE_TIMEOUT_MS=45000
QQ_VOICE_SYNTH_TIMEOUT_MS=300000
# Laptop-local GPT-SoVITS is configured separately in config/voice-tts.local.env.
# OpenAI-compatible API for automation / decision / fallback text chains
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=deepseek/deepseek-reasoner

# Long Memory v3
MEMORY_V3_ENABLED=true
MEMORY_V3_READ_ENABLED=true
MEMORY_V3_WRITE_ENABLED=true
MEMORY_V3_EXTRACT_BASE_URL=https://api.siliconflow.cn/v1
MEMORY_V3_EXTRACT_API_KEY=
MEMORY_V3_EXTRACT_MODEL=Qwen/Qwen3.5-35B-A3B
MEMORY_V3_EXTRACT_TIMEOUT_MS=60000
MEMORY_V3_EXTRACT_REQUEST_MODE=chat_completions
MEMORY_V3_EXTRACT_STRUCTURED_OUTPUT_PROTOCOL=native_chat_json_schema
MEMORY_V3_EXTRACT_SUPPORTS_JSON_MODE=false
MEMORY_V3_EMBED_BASE_URL=https://api.siliconflow.cn/v1
MEMORY_V3_EMBED_API_KEY=sk-xxxx
MEMORY_V3_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
MEMORY_V3_EMBED_TIMEOUT_MS=12000
MEMORY_V3_QUERY_TOPK=8
MEMORY_V3_PROMPT_BUDGET_TOKENS=1200
MEMORY_V3_EMBED_BATCH_SIZE=16
MEMORY_V3_EXTRACT_IDLE_MS=90000
MEMORY_V3_EXTRACT_MESSAGE_BATCH=12
MEMORY_V3_ARCHIVE_DAYS=90
MEMORY_V3_MAX_JOB_RETRIES=5
MEMORY_V3_JOB_LOCK_TIMEOUT_MS=300000

# ChatLuna Search Service (Tavily)
CHATLUNA_SEARCH_SERVICE_ENABLED=true
CHATLUNA_SEARCH_SERVICE_TOPK=5
CHATLUNA_SEARCH_SERVICE_SUMMARY_TYPE=balanced
CHATLUNA_SEARCH_SERVICE_SUMMARY_MODEL=empty
CHATLUNA_SEARCH_SERVICE_TAVILY_API_KEY=

# ChatLuna Common Tools (通用工具插件)
CHATLUNA_COMMON_THINK=false
CHATLUNA_COMMON_SEND=true
CHATLUNA_COMMON_TODOS=false
CHATLUNA_COMMON_CHAT=true
CHATLUNA_COMMON_REQUEST=true
CHATLUNA_COMMON_REQUEST_MAX_OUTPUT_LENGTH=58600
CHATLUNA_COMMON_FS=false
CHATLUNA_COMMON_FS_SCOPE_PATH=
CHATLUNA_COMMON_COMMAND=false
CHATLUNA_COMMON_COMMAND_AUTO_EXECUTE=false
CHATLUNA_COMMON_CRON=false
CHATLUNA_COMMON_GROUP=false
CHATLUNA_COMMON_ACTIONS=true

# ChatLuna MCP Client
# 默认通过 chatluna.mcp.add / chatluna.mcp.remove 动态维护服务器配置

# Sticker (表情包)
CHATLUNA_STICKER_DIR=./data/chathub/stickers
STICKER_INDEXER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STICKER_INDEXER_API_KEY=
STICKER_INDEXER_MODEL=doubao-seed-2-0-mini-260215
STICKER_INDEXER_TIMEOUT_MS=60000

# ChatLuna Live Reply (发送期可中断续写)
QQBOT_REPLY_INTERRUPT_ENABLED=false
QQBOT_REPLY_COLLECT_WINDOW_MS=400
QQBOT_REPLY_MAX_PENDING_INPUTS=8

# PMHQ container + host LLBot runtime
PMHQ_IMAGE=docker.io/linyuchen/pmhq
PMHQ_TAG=latest
LLBOT_VERSION=7.12.15
LLBOT_RUNTIME_DIR=./.runtime/llbot
# Optional override for PMHQ QQ volume mount source when podman inspect is unavailable.
QQBOT_QQ_CONFIG_MOUNT_SOURCE=
ENABLE_HEADLESS=false
AUTO_LOGIN_QQ=
LLONEBOT_DATA_DIR=./.runtime/llonebot
LLONEBOT_DISABLE_WEBUI_AUTH=true
PMHQ_BIND_HOST=127.0.0.1
PMHQ_PORT=13000
LLONEBOT_WEBUI_PORT=3080
LLONEBOT_WS_PORT=3001
VOICE_ASR_PORT=5161
VOICE_ASR_MODEL=small
VOICE_ASR_COMPUTE_TYPE=int8
TZ=Asia/Shanghai
