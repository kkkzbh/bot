{
  "name": "qqbot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "description": "QQ group AI chat bot powered by Koishi + OneBot on Fedora/Podman",
  "scripts": {
    "chatluna:build": "bash ./scripts/ensure-chatluna-build.sh",
    "build": "rm -rf dist node_modules/.cache/qqbot-bot-console && tsc -p tsconfig.build.json && pnpm console:build",
    "console:build": "vite build --config src/plugins/bot-console/client/vite.config.ts",
    "console:dev": "vite build --config src/plugins/bot-console/client/vite.config.ts --watch",
    "dev": "pnpm start",
    "docs:dev": "vitepress dev web",
    "docs:build": "vitepress build web",
    "docs:preview": "vitepress preview web",
    "start": "bash ./scripts/run-koishi-with-env.sh",
    "start:local": "QQBOT_ENV_FILE=.env.local bash ./scripts/run-koishi-with-env.sh",
    "start:server": "QQBOT_ENV_FILE=.env.server bash ./scripts/run-koishi-with-env.sh",
    "smoke:start": "bash ./scripts/smoke-koishi-start.sh",
    "smoke:chat": "bash ./scripts/smoke-chat-replies.sh",
    "stickers:sync": "node ./scripts/stickers-sync.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@koishijs/plugin-analytics": "2.0.6",
    "@koishijs/plugin-commands": "3.5.5",
    "@koishijs/plugin-config": "2.8.6",
    "@koishijs/plugin-console": "5.30.11",
    "@koishijs/plugin-database-sqlite": "4.7.0",
    "@koishijs/plugin-http": "0.6.3",
    "@koishijs/plugin-insight": "3.5.2",
    "@koishijs/plugin-logger": "2.6.9",
    "@koishijs/plugin-market": "2.11.11",
    "@koishijs/plugin-proxy-agent": "0.3.3",
    "@koishijs/plugin-sandbox": "3.4.2",
    "@koishijs/plugin-server": "3.2.9",
    "@koishijs/plugin-status": "7.4.10",
    "@langchain/core": "^0.3.80",
    "@napi-rs/canvas": "^0.1.97",
    "cron-parser": "^4.9.0",
    "koishi": "4.18.11",
    "koishi-plugin-adapter-onebot": "6.9.3",
    "koishi-plugin-canvas": "0.2.2",
    "koishi-plugin-chatluna": "link:../chatluna/packages/core",
    "koishi-plugin-chatluna-agent": "link:../chatluna/packages/extension-agent",
    "koishi-plugin-chatluna-mcp-client": "1.3.4",
    "koishi-plugin-chatluna-openai-like-adapter": "link:../chatluna/packages/adapter-openai-like",
    "koishi-plugin-chatluna-plugin-common": "link:../chatluna/packages/extension-tools",
    "koishi-plugin-chatluna-search-service": "link:../chatluna/packages/service-search",
    "koishi-plugin-chatluna-storage-service": "1.0.6",
    "koishi-plugin-cron": "3.1.0",
    "koishi-plugin-downloads": "0.1.3",
    "koishi-plugin-pokemon-battle": "1.1.13",
    "koishi-plugin-puppeteer": "3.9.0",
    "yaml": "^2.8.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.28"
  }
}
