# Server bot runtime template
# Copy to .env.server for server deploy/runtime.

# Core Bot
BOT_OWNER_QQ=2219854433
ONEBOT_SELF_ID=100000001
ONEBOT_WS_ENDPOINT=ws://127.0.0.1:3001
ONEBOT_TOKEN=
KOISHI_HOST=0.0.0.0
KOISHI_PORT=5140
KOISHI_CONSOLE_UI_PATH=/console
SQLITE_PATH=./data/koishi.db
CHATLUNA_COMMAND_AUTHORITY=3
TRACE_VIEWER_ENABLED=true
TRACE_VIEWER_UI_PATH=/trace
TRACE_VIEWER_API_PATH=/trace/api
TRACE_VIEWER_RETENTION_DAYS=7
TRACE_VIEWER_MAX_SESSIONS=500
TRACE_VIEWER_MAX_EVENT_PAYLOAD_BYTES=65536
TRACE_VIEWER_POLL_INTERVAL_MS=2000
TRACE_VIEWER_REDACT_SECRETS=true

# Pokemon Battle (宝可梦对战插件)
POKEMON_BATTLE_ENABLED=true
POKEMON_BATTLE_IMAGE_SOURCE=https://raw.githubusercontent.com/MAIxxxIAM/pokemonFusionImage/main
POKEMON_DOWNLOADS_OUTPUT=./downloads

# Group Natural Trigger (群聊自然触发)
CHAT_NATURAL_TRIGGER_ENABLED=true
CHAT_NATURAL_TRIGGER_GROUPS=
CHAT_NATURAL_TRIGGER_ALIASES=祥子,祥,丰川,丰川祥子,saki,saki酱,sakiko
CHAT_NATURAL_TRIGGER_DIRECT_PROBABILITY=0.25
CHAT_NATURAL_TRIGGER_FOCUS_WINDOW_MS=300000
CHAT_NATURAL_TRIGGER_REPLY_INTERVAL_MS=2000
CHAT_NATURAL_TRIGGER_SPAM_WINDOW_MS=10000
CHAT_NATURAL_TRIGGER_SPAM_THRESHOLD=10
CHAT_NATURAL_TRIGGER_SPAM_MUTE_MS=180000
CHAT_NATURAL_TRIGGER_DECISION_ENABLED=true
CHAT_NATURAL_TRIGGER_DECISION_BASE_URL=
CHAT_NATURAL_TRIGGER_DECISION_API_KEY=
CHAT_NATURAL_TRIGGER_DECISION_MODEL=
CHAT_NATURAL_TRIGGER_DECISION_TIMEOUT_MS=4000
CHAT_NATURAL_TRIGGER_DECISION_MIN_CONFIDENCE=0.62

# Task Automation (智能定时任务)
CHAT_ENABLED_GROUPS=123456789,987654321
TASK_AUTOMATION_LISTEN_PRIVATE=true
TASK_AUTOMATION_PERMISSION=all
TASK_AUTOMATION_INTENT_ENABLED=true
TASK_AUTOMATION_INTENT_MIN_CONFIDENCE=0.78
TASK_AUTOMATION_INTENT_BASE_URL=
TASK_AUTOMATION_INTENT_API_KEY=
TASK_AUTOMATION_INTENT_MODEL=
TASK_AUTOMATION_INTENT_TIMEOUT_MS=12000
TASK_AUTOMATION_POLL_MS=30000
TASK_AUTOMATION_MAX_TASKS_PER_USER=20
TASK_AUTOMATION_DELIVERY_MODEL=deepseek-reasoner
TASK_AUTOMATION_DELIVERY_TIMEOUT_MS=18000
TASK_AUTOMATION_DELIVERY_MAX_TOKENS=10000
TASK_AUTOMATION_CHAT_REPLY_MODEL=deepseek-reasoner
TASK_AUTOMATION_CHAT_REPLY_TIMEOUT_MS=12000
TASK_AUTOMATION_CHAT_REPLY_MAX_TOKENS=10000

# QQ Voice (QQ 语音输入/输出)
QQ_VOICE_ENABLED=true
QQ_VOICE_INPUT_ENABLED=true
QQ_VOICE_OUTPUT_ENABLED=true
QQ_VOICE_ASR_BASE_URL=http://127.0.0.1:5161
QQ_VOICE_ASR_API_KEY=qqbot-voice-asr-token
QQ_VOICE_TTS_BASE_URL=http://your-laptop.tailnet.ts.net:5162
QQ_VOICE_TTS_API_KEY=qqbot-voice-tts-token
QQ_VOICE_INPUT_MAX_SECONDS=60
QQ_VOICE_OUTPUT_MAX_WORDS=80
QQ_VOICE_OUTPUT_MAX_SECONDS=45
QQ_VOICE_TRANSCRIBE_TIMEOUT_MS=45000
QQ_VOICE_SYNTH_TIMEOUT_MS=300000
# Laptop-local GPT-SoVITS is configured separately in config/voice-tts.local.env.

# OpenAI-compatible API (used by ChatLuna DeepSeek adapter)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=deepseek/deepseek-reasoner

# ChatLuna Ollama Adapter (self-hosted/free embeddings)
CHATLUNA_OLLAMA_ENABLED=true
CHATLUNA_OLLAMA_ENDPOINT=http://127.0.0.1:11434
CHATLUNA_OLLAMA_KEEP_ALIVE=true
OLLAMA_IMAGE=docker.io/ollama/ollama
OLLAMA_TAG=latest
OLLAMA_PORT=11434
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Local Web Search (本地搜索插件)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TOPK=5
WEB_SEARCH_TIMEOUT_MS=12000
WEB_SEARCH_PROVIDERS=bing-web,duckduckgo-lite,wikipedia
WEB_SEARCH_LLM_BASE_URL=https://api.deepseek.com/v1
WEB_SEARCH_LLM_API_KEY=
WEB_SEARCH_LLM_MODEL=deepseek-chat
WEB_SEARCH_LLM_PLANNER_ENABLED=true
WEB_SEARCH_LLM_RERANK_ENABLED=true
WEB_SEARCH_ACGN_EXTENSION_ENABLED=false

# ChatLuna Common Tools (通用工具插件)
CHATLUNA_COMMON_THINK=false
CHATLUNA_COMMON_SEND=true
CHATLUNA_COMMON_TODOS=false
CHATLUNA_COMMON_CHAT=true
CHATLUNA_COMMON_REQUEST=true
CHATLUNA_COMMON_REQUEST_MAX_OUTPUT_LENGTH=58600
CHATLUNA_COMMON_FS=false
CHATLUNA_COMMON_FS_SCOPE_PATH=
CHATLUNA_COMMON_COMMAND=false
CHATLUNA_COMMON_COMMAND_AUTO_EXECUTE=false
CHATLUNA_COMMON_CRON=false
CHATLUNA_COMMON_GROUP=false
CHATLUNA_COMMON_ACTIONS=true

# ChatLuna MCP Client
# 默认通过 chatluna.mcp.add / chatluna.mcp.remove 动态维护服务器配置

# ChatLuna Embeddings + Vector Store
# 默认使用本地 Ollama 的免费 embedding 模型
CHATLUNA_DEFAULT_EMBEDDINGS=ollama/nomic-embed-text:latest
CHATLUNA_DEFAULT_VECTOR_STORE=luna-vdb
CHATLUNA_VECTOR_STORE=luna-vdb
CHATLUNA_VECTOR_STORE_REDIS_URL=redis://127.0.0.1:6379
CHATLUNA_VECTOR_STORE_MILVUS_URL=http://127.0.0.1:19530
CHATLUNA_VECTOR_STORE_MILVUS_USERNAME=
CHATLUNA_VECTOR_STORE_MILVUS_PASSWORD=

# ChatLuna Long Memory
CHATLUNA_LONG_MEMORY_EXTRACT_MODEL=deepseek/deepseek-chat
CHATLUNA_LONG_MEMORY_EXTRACT_INTERVAL=3
CHATLUNA_LONG_MEMORY_QUERY_REWRITE=true
CHATLUNA_HIPPO_EXTRACT_MODEL=deepseek/deepseek-chat

# Sticker (表情包)
CHATLUNA_STICKER_DIR=./data/chathub/stickers
STICKER_INDEXER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STICKER_INDEXER_API_KEY=
STICKER_INDEXER_MODEL=doubao-seed-2-0-mini-260215
STICKER_INDEXER_TIMEOUT_MS=60000

# ChatLuna Live Reply (发送期可中断续写)
QQBOT_LIVE_REPLY_ENABLED=false
QQBOT_LIVE_REPLY_COLLECT_WINDOW_MS=600
QQBOT_LIVE_REPLY_MAX_PENDING_MESSAGES=8
QQBOT_LIVE_REPLY_HISTORY_REWRITE_FALLBACK=queue

# Container stack (ollama + pmhq + llbot)
PMHQ_IMAGE=docker.io/linyuchen/pmhq
PMHQ_TAG=latest
LLBOT_IMAGE=docker.io/linyuchen/llbot
LLBOT_TAG=latest
ENABLE_HEADLESS=false
AUTO_LOGIN_QQ=
LLONEBOT_WEBUI_PORT=3080
LLONEBOT_WS_PORT=3001
VOICE_ASR_PORT=5161
VOICE_ASR_MODEL=small
VOICE_ASR_COMPUTE_TYPE=int8
TZ=Asia/Shanghai
